{
  "name": "km-api",
  "version": "0.3.0",
  "description": "Type-safe API schema builder for TypeScript — define HTTP endpoints with Zod validation, full OpenAPI 3.0 compatibility, and adapters for Axios, Fetch, and Alova.",
  "license": "MIT",
  "author": "komeilm76",
  "homepage": "https://github.com/komeilm76/km-api#readme",
  "bugs": {
    "url": "https://github.com/komeilm76/km-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komeilm76/km-api.git"
  },
  "main": "build/js/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/index.d.ts",
  "typings": "build/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./build/types/index.d.ts",
      "require": "./build/cjs/index.cjs",
      "import": "./build/esm/index.mjs",
      "default": "./build/js/index.js"
    },
    "./esm": {
      "types": "./build/esm/index.d.mts",
      "import": "./build/esm/index.mjs"
    },
    "./js": {
      "types": "./build/js/index.d.mts",
      "default": "./build/js/index.js"
    },
    "./cjs": {
      "types": "./build/cjs/index.d.ts",
      "require": "./build/cjs/index.cjs"
    }
  },
  "files": [
    "build",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "api",
    "openapi",
    "swagger",
    "rest-api",
    "typescript",
    "type-safe",
    "zod",
    "schema-validation",
    "api-schema",
    "api-config",
    "http-client",
    "axios",
    "fetch",
    "alova",
    "endpoint",
    "request",
    "response",
    "km-api",
    "km-packages",
    "openapi3",
    "swagger2"
  ],
  "scripts": {
    "fix:prettier": "prettier \"src/**/*.{ts,json}\" --write && prettier \"*.json\" --write",
    "fix": "bun run fix:prettier",
    "dev": "bun --watch run ./src/index.ts",
    "build:types": "tsc",
    "build:tsup": "bun run build:types && tsup",
    "build": "bun run build:types && bun run build:tsup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "publish-directly": "npm publish --access public",
    "auto-release": "npm run fix:prettier && npm run build && npm test && release-it"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "prettier": "^2.1.1",
    "release-it": "^19.2.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=14"
  }
}
